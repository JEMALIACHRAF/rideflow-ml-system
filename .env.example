# .env.example — copy to .env and fill in your values
# All settings have sensible defaults in config.py

# ── Redis ──────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_TTL_SECONDS=300

# ── Kafka ──────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_GPS=rideflow.gps
KAFKA_TOPIC_WEATHER=rideflow.weather
KAFKA_TOPIC_EVENTS=rideflow.events

# ── MLflow ─────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=rideflow-demand

# ── API ────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_CACHE_TTL=60

# ── Training ───────────────────────────────────────────────────
TRAIN_START=2024-01-01
TRAIN_END=2024-09-30
VAL_START=2024-10-01
VAL_END=2024-11-30
TEST_START=2024-12-01
TEST_END=2024-12-31
OPTUNA_N_TRIALS=200
